# Copy to .env and fill in the blanks.

# --- subnet ---
# netuid 1 is preoccupied on localnet; bootstrap assigns netuid 2.
NETUID=2

# Tempo = epoch length in blocks. Not currently configurable across the stack —
# set only for the localnet subtensor so tempo matches other services' defaults.
SUBNET_TEMPO=360

# --- pylon connection (read from env by EnvPylonClientProvider and compose.yml) ---
VALIDATOR_PYLON_SERVICE_ADDRESS=http://localhost:8000
VALIDATOR_PYLON_OPEN_ACCESS_TOKEN=localnet-open-access-token
VALIDATOR_PYLON_IDENTITY_NAME=validator
VALIDATOR_PYLON_IDENTITY_TOKEN=localnet-validator-token

# --- validator settings ---
VALIDATOR_NETUID=2
# Externally reachable IP of this validator, advertised to miners for async callbacks.
VALIDATOR_EXTERNAL_IP=127.0.0.1

# OpenRouter API key used by the VLM judge.
VALIDATOR_OPENROUTER_API_KEY=
